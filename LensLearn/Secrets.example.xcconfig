// Secrets.example.xcconfig — template, safe to commit.
//
// Setup:
//   1. Copy this file to `Secrets.xcconfig` (same folder).
//   2. Paste your Google AI Studio API key after the `=` below.
//   3. Build & run. `Secrets.xcconfig` is git-ignored — your key stays local.
GEMINI_API_KEY = YOUR_API_KEY_HERE
